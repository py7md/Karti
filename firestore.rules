rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Static identifier & serial validation function
    function isValidSerial(serial) {
      return serial is string && 
             serial.size() == 13 && 
             serial.matches('^DAH-[A-Z0-9]{4}-[A-Z0-9]{4}$');
    }

    // Match block for activated_serials:
    // Allows any device with a valid serial to claim it.
    match /activated_serials/{serial} {
      allow read, write: if isValidSerial(serial);
    }

    // Match block for backups:
    // Allows any device with a valid serial to save or restore their backups reliably.
    match /backups/{serial} {
      allow read, write: if isValidSerial(serial);
    }
  }
}
